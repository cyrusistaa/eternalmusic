# Discord
DISCORD_TOKEN=your_bot_token
DISCORD_CLIENT_ID=your_application_client_id

# Optional: faster command registration (single guild)
# DISCORD_GUILD_ID=your_test_guild_id

# Optional: bot starts idling in this voice channel on boot
# IDLE_VOICE_CHANNEL_ID=123456789012345678

# Optional: resolve Spotify track links into a search query (audio is still played from YouTube)
# SPOTIFY_CLIENT_ID=your_spotify_client_id
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

